{
  "$schema": "https://www.mintlify.com/docs.json",
  "theme": "mint",
  "name": "Datum Cloud Docs",
  "logo": {
    "light": "https://www.datum.net/datum-light.svg",
    "dark": "https://www.datum.net/datum-dark.svg",
    "href": "https://www.datum.net/"
  },
  "favicon": "https://www.datum.net/favicons/favicon-dark-128x128.png",
  "colors": {
    "primary": "#BF9595",
    "light": "#ECD0D0",
    "dark": "#4D6356"
  },
  "navbar": {
    "links": [
      {
        "label": "Status",
        "href": "https://www.datumstatus.net/"
      },
      {
        "type": "button",
        "label": "Dashboard",
        "href": "https://cloud.datum.net"
      }
    ]
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Discord",
          "icon": "discord",
          "href": "https://link.datum.net/discord"
        },
        {
          "anchor": "YouTube",
          "icon": "youtube",
          "href": "https://link.datum.net/youtube"
        },
        {
          "anchor": "GitHub",
          "icon": "github",
          "href": "https://link.datum.net/github"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Docs",
        "icon": "layer-group",
        "groups": [
          {
            "group": "Documentation",
            "pages": [
              "index"
            ]
          },
          {
            "group": "TLDR",
            "pages": [
              "overview",
              "features",
              "kubernetes",
              "get-involved"
            ]
          },
          {
            "group": "Platform",
            "pages": [
              "platform/setup",
              "platform/service-accounts",
              "platform/metrics-export",
              "platform/activity-logs",
              "platform/secrets",
              "platform/locations"
            ]
          },
          {
            "group": "AI Edge",
            "pages": [
              "ai-edge/overview",
              {
                "group": "Guides",
                "pages": [
                  "ai-edge/guides/basic-auth",
                  "ai-edge/guides/oidc-google",
                  "ai-edge/guides/oidc-auth0"
                ]
              }
            ]
          },
          {
            "group": "Connectors",
            "pages": [
              "connectors/tunnels"
            ]
          },
          {
            "group": "Galactic VPC",
            "pages": [
              "galactic-vpc/overview"
            ]
          },
          {
            "group": "Domains & DNS",
            "pages": [
              "domain-dns/domains",
              "domain-dns/dns"
            ]
          },
          {
            "group": "Agents",
            "pages": [
              "agents/overview",
              {
                "group": "Skills",
                "pages": [
                  "agents/skills/index",
                  "agents/skills/ai-edge",
                  "agents/skills/client-traffic",
                  "agents/skills/dns",
                  "agents/skills/domains",
                  "agents/skills/httproute",
                  "agents/skills/metrics-export"
                ]
              },
              "datum-mcp",
              "agents/llms-txt"
            ]
          },
          {
            "group": "Tools",
            "pages": [
              "desktop-apps"
            ]
          }
        ]
      },
      {
        "tab": "datumctl (CLI)",
        "icon": "terminal",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "datumctl/overview",
              "datumctl/quickstart"
            ]
          },
          {
            "group": "Authentication",
            "pages": [
              "datumctl/auth/logging-in",
              "datumctl/auth/service-accounts",
              "datumctl/auth/managing-accounts"
            ]
          },
          {
            "group": "Core concepts",
            "pages": [
              "datumctl/contexts-and-scoping",
              "datumctl/discovering-resources",
              "datumctl/output-and-scripting"
            ]
          },
          {
            "group": "Working with resources",
            "pages": [
              "datumctl/resources/reading",
              "datumctl/resources/changing",
              "datumctl/resources/safe-changes"
            ]
          },
          {
            "group": "Plugins",
            "pages": [
              "datumctl/plugins/using-plugins",
              "datumctl/plugins/adding-catalogs",
              "datumctl/plugins/publishing-catalogs",
              "datumctl/plugins/building-plugins"
            ]
          },
          {
            "group": "Activity & audit",
            "pages": [
              "datumctl/activity/overview",
              "datumctl/activity/audit-and-events",
              "datumctl/activity/change-history-and-feed"
            ]
          },
          {
            "group": "Interactive console",
            "pages": [
              "datumctl/console"
            ]
          },
          {
            "group": "AI & MCP",
            "pages": [
              "datumctl/ai/assistant",
              "datumctl/ai/mcp-server"
            ]
          },
          {
            "group": "Developer tooling",
            "pages": [
              "datumctl/api-proxy"
            ]
          },
          {
            "group": "CI/CD",
            "pages": [
              "datumctl/cicd/github-actions",
              "datumctl/cicd/automating"
            ]
          },
          {
            "group": "Kubernetes interop",
            "pages": [
              "datumctl/kubectl-interop",
              "datumctl/kubernetes-tools",
              "datumctl/gitops"
            ]
          }
        ]
      }
    ]
  },
  "search": {
    "prompt": "Search..."
  },
  "ai": {
    "type": "chat"
  },
  "seo": {
    "indexing": "all",
    "metatags": {
      "og:image": "https://www.datum.net/docs/images/og-doc.png",
      "canonical": "https://www.datum.net/docs"
    }
  },
  "feedback": {
    "thumbsRating": true
  },
  "contextual": {
    "options": [
      "claude",
      "chatgpt",
      "copy",
      "view"
    ]
  },
  "integrations": {
    "fathom": {
      "siteId": "PXKRQKIZ"
    }
  },
  "errors": {
    "404": {
      "title": "Datum Docs Error Page",
      "description": "Looks like you've found a problem. Please visit our docs homepage and we'll take a look. Thanks!"
    }
  },
  "metadata": {
    "timestamp": true
  },
  "interaction": {
    "drilldown": true
  },
  "footer": {
    "socials": {
      "discord": "https://link.datum.net/discord",
      "linkedin": "https://link.datum.net/linkedin",
      "youtube": "https://link.datum.net/youtube",
      "github": "https://link.datum.net/github"
    }
  },
  "description": "Learn about Datum's open network cloud",
  "appearance": {
    "default": "system"
  },
  "icons": {
    "library": "fontawesome"
  },
  "background": {
    "color": {
      "dark": "#0C1D31",
      "light": "#F6F6F5"
    }
  },
  "fonts": {
    "family": "Inter",
    "heading": {
      "family": "Inter"
    },
    "body": {
      "family": "Inter"
    }
  },
  "api": {
    "examples": {
      "autogenerate": false,
      "prefill": false
    }
  }
}