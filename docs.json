{
  "$schema": "https://www.mintlify.com/docs.json",
  "theme": "maple",
  "name": "Datum Documentation",
  "logo": {
    "light": "https://www.datum.net/datum-light.svg",
    "dark": "https://www.datum.net/datum-dark.svg",
    "href": "https://www.datum.net/"
  },
  "favicon": {
    "light": "https://www.datum.net/favicons/favicon-light-128x128.png",
    "dark": "https://www.datum.net/favicons/favicon-dark-128x128.png"
  },
  "colors": {
    "primary": "#9C7979",
    "light": "#E6F59F",
    "dark": "#C8E86A"
  },
  "navbar": {
    "links": [
      {
        "label": "Status",
        "href": "https://www.datumstatus.net/"
      }
    ]
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "icon": "layer-group",
        "pages": [
          "docs/quickstart",
          {
            "group": "Platform",
            "pages": [
              "docs/platform/account",
              "docs/platform/orgs-projects",
              "docs/platform/limits",
              "docs/platform/metrics-export",
              "docs/platform/activity-logs",
              "docs/platform/secrets"
            ]
          },
          {
            "group": "AI Edge",
            "pages": [
              "docs/ai-edge/overview",
              "docs/ai-edge/configuration",
              "docs/ai-edge/troubleshooting"
            ]
          },
          {
            "group": "Connectors",
            "pages": [
              "docs/connectors/overview",
              "docs/connectors/tunnels"
            ]
          },
          {
            "group": "Galactic VPC",
            "pages": [
              "docs/galactic-vpc/overview"
            ]
          },
          {
            "group": "Domains & DNS",
            "pages": [
              "docs/domain-dns/domains",
              "docs/domain-dns/dns",
              "docs/domain-dns/faqs"
            ]
          },
          {
            "group": "Tools",
            "pages": [
              "docs/desktop-apps",
              "docs/mcp"
            ]
          }
        ]
      },
      {
        "tab": "datumctl (CLI)",
        "icon": "terminal",
        "pages": [
          "docs/datumctl/overview",
          "docs/datumctl/authentication",
          "docs/datumctl/activity"
        ]
      },
      {
        "tab": "CLI Commands",
        "icon": "rectangle-list",
        "pages": [
          "docs/cli/options",
          {
            "group": "Authentication",
            "pages": [
              "docs/cli/datumctl_auth"
            ]
          },
          {
            "group": "Resource Management",
            "pages": [
              "docs/cli/datumctl_apply",
              "docs/cli/datumctl_create",
              "docs/cli/datumctl_delete",
              "docs/cli/datumctl_describe",
              "docs/cli/datumctl_diff",
              "docs/cli/datumctl_edit",
              "docs/cli/datumctl_get"
            ]
          },
          {
            "group": "Discovery",
            "pages": [
              "docs/cli/datumctl_api-resources",
              "docs/cli/datumctl_api-versions",
              "docs/cli/datumctl_explain"
            ]
          },
          {
            "group": "Activity",
            "pages": [
              "docs/cli/datumctl_activity"
            ]
          },
          {
            "group": "Tools",
            "pages": [
              "docs/cli/datumctl_completion",
              "docs/cli/datumctl_docs",
              "docs/cli/datumctl_mcp"
            ]
          }
        ]
      },
      {
        "tab": "Guides",
        "icon": "map",
        "pages": [
          "docs/guides/protect-an-app",
          "docs/guides/expose-localhost",
          "docs/guides/custom-domain-github-pages"
        ]
      }
    ]
  },
  "search": {
    "prompt": "Search..."
  },
  "feedback": {
    "thumbsRating": true
  },
  "contextual": {
    "options": ["copy", "chatgpt", "claude"]
  },
  "integrations": {
    "fathom": {
      "siteId": "PXKRQKIZ"
    }
  },
  "errors": {
    "404": {
      "title": "Datum Docs Error Page",
      "description": "Looks like you've found a problem. Please visit our docs homepage and we'll take a look. Thanks!"
    }
  },
  "metadata": {
    "timestamp": true
  },
  "interaction": {
    "drilldown": true
  },
  "footer": {
    "socials": {
      "discord": "https://link.datum.net/discord",
      "linkedin": "https://link.datum.net/linkedin",
      "youtube": "https://link.datum.net/youtube"
    }
  },
  "background": {
    "color": {
      "dark": "#0C1D31",
      "light": "#F6F6F5"
    }
  },
  "appearance": {
    "default": "light"
  },
  "fonts": {
    "family": "Inter",
    "heading": {
      "family": "Inter"
    },
    "body": {
      "family": "Inter"
    }
  }
}
