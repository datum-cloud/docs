{
  "$schema": "https://www.mintlify.com/docs.json",
  "theme": "mint",
  "name": "Datum Cloud Docs",
  "logo": {
    "light": "https://www.datum.net/datum-light.svg",
    "dark": "https://www.datum.net/datum-dark.svg",
    "href": "https://www.datum.net/"
  },
  "favicon": {
    "light": "https://www.datum.net/favicons/favicon-light-128x128.png",
    "dark": "https://www.datum.net/favicons/favicon-light-128x128.png"
  },
  "colors": {
    "primary": "#BF9595",
    "light": "#ECD0D0",
    "dark": "#4D6356"
  },
  "navbar": {
    "links": [
      {
        "label": "Status",
        "href": "https://www.datumstatus.net/"
      },
      {
        "type": "button",
        "label": "Dashboard",
        "href": "https://app.datum.net"
      }
    ]
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Discord",
          "icon": "discord",
          "href": "https://link.datum.net/discord"
        },
        {
          "anchor": "YouTube",
          "icon": "youtube",
          "href": "https://link.datum.net/youtube"
        },
        {
          "anchor": "GitHub",
          "icon": "github",
          "href": "https://link.datum.net/github"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Docs",
        "icon": "layer-group",
        "groups": [
          {
            "group": "TLDR",
            "pages": [
              "overview",
              "features",
              "kubernetes",
              "get-involved"
            ]
          },
          {
            "group": "Platform",
            "pages": [
              "platform/setup",
              "platform/metrics-export",
              "platform/activity-logs",
              "platform/secrets",
              "platform/locations"
            ]
          },
          {
            "group": "AI Edge",
            "pages": [
              "ai-edge/overview"
            ]
          },
          {
            "group": "Connectors",
            "pages": [
              "connectors/tunnels"
            ]
          },
          {
            "group": "Galactic VPC",
            "pages": [
              "galactic-vpc/overview"
            ]
          },
          {
            "group": "Domains & DNS",
            "pages": [
              "domain-dns/domains",
              "domain-dns/dns"
            ]
          },
          {
            "group": "Tools",
            "pages": [
              "desktop-apps",
              "datum-mcp"
            ]
          }
        ]
      },
      {
        "tab": "datumctl (CLI)",
        "icon": "terminal",
        "pages": [
          "datumctl/overview",
          "datumctl/authentication",
          "datumctl/activity"
        ]
      },
      {
        "tab": "CLI Commands",
        "icon": "rectangle-list",
        "pages": [
          "cli/options",
          {
            "group": "Authentication",
            "pages": [
              "cli/datumctl_auth"
            ]
          },
          {
            "group": "Resource Management",
            "pages": [
              "cli/datumctl_apply",
              "cli/datumctl_create",
              "cli/datumctl_delete",
              "cli/datumctl_describe",
              "cli/datumctl_diff",
              "cli/datumctl_edit",
              "cli/datumctl_get"
            ]
          },
          {
            "group": "Discovery",
            "pages": [
              "cli/datumctl_api-resources",
              "cli/datumctl_api-versions",
              "cli/datumctl_explain"
            ]
          },
          {
            "group": "Activity",
            "pages": [
              "cli/datumctl_activity"
            ]
          },
          {
            "group": "Tools",
            "pages": [
              "cli/datumctl_completion",
              "cli/datumctl_docs",
              "cli/datumctl_mcp"
            ]
          }
        ]
      },
      {
        "tab": "Guides",
        "icon": "map",
        "hidden": true,
        "pages": [
          "guides/github-custom-domain",
          "guides/mintlify-custom-domain"
        ]
      }
    ]
  },
  "search": {
    "prompt": "Search..."
  },
  "ai": {
    "type": "chat"
  },
  "seo": {
    "indexing": "all",
    "metatags": {
      "og:image": "https://www.datum.net/docs/images/og-doc.png"
    }
  },
  "feedback": {
    "thumbsRating": true
  },
  "contextual": {
    "options": [
      "claude",
      "chatgpt",
      "copy",
      "view"
    ]
  },
  "integrations": {
    "fathom": {
      "siteId": "PXKRQKIZ"
    }
  },
  "errors": {
    "404": {
      "title": "Datum Docs Error Page",
      "description": "Looks like you've found a problem. Please visit our docs homepage and we'll take a look. Thanks!"
    }
  },
  "metadata": {
    "timestamp": true
  },
  "interaction": {
    "drilldown": true
  },
  "footer": {
    "socials": {
      "discord": "https://link.datum.net/discord",
      "linkedin": "https://link.datum.net/linkedin",
      "youtube": "https://link.datum.net/youtube",
      "github": "https://link.datum.net/github"
    }
  },
  "description": "Learn about Datum's open network cloud",
  "appearance": {
    "default": "system"
  },
  "icons": {
    "library": "fontawesome"
  },
  "background": {
    "color": {
      "dark": "#0C1D31",
      "light": "#F6F6F5"
    }
  },
  "fonts": {
    "family": "Inter",
    "heading": {
      "family": "Inter"
    },
    "body": {
      "family": "Inter"
    }
  }
}